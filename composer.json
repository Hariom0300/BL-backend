{
    "name": "hariom0300/bl-backend",
    "description": "Dongare E-commerce Backend API",
    "version": "1.0.0",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt": "^6.0",
        "phpmailer/phpmailer": "^6.8",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "BLBackend\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:10000",
        "test": "phpunit",
        "migrate": "php migrate.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "ecommerce",
        "api",
        "php",
        "dongare",
        "fashion"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Hariom Vimal",
            "email": "hariomvimal33333@gmail.com"
        }
    ],
    "support": {
        "email": "hariomvimal33333@gmail.com"
    }
}
